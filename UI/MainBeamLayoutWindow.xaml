<Window x:Class="RevitAgent.UI.MainBeamLayoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="主梁布置"
        Width="460"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0"
                  Header="1) 框选元素（可多选）"
                  FontSize="14">
            <StackPanel Orientation="Vertical" Margin="10">
                <Button x:Name="SelectColumnsButton"
                        Content="框选元素"
                        Width="110"
                        Height="28"
                        HorizontalAlignment="Left"
                        Click="SelectColumnsButton_Click"/>
                <TextBlock x:Name="SelectedColumnsTextBlock"
                           Text="尚未选择元素"
                           FontSize="12"
                           Margin="0,8,0,0"
                           Foreground="Gray"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <TextBlock Grid.Row="2"
                   Foreground="Gray"
                   FontSize="11"
                   TextWrapping="Wrap">
            说明：命令启动时会自动创建“布置方案平面”，并在该平面中绘制主梁模型线。请至少选择 3 个结构柱。
        </TextBlock>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Width="100"
                    Height="28"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Content="确定"
                    Click="OnOkClick"/>
            <Button x:Name="CancelButton"
                    Width="90"
                    Height="28"
                    Content="取消"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
